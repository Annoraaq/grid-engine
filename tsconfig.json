{
  "compilerOptions": {
    "target": "es6",
    "declaration": true,
    "allowJs": false,
    "strictNullChecks": true,
    "strictPropertyInitialization": true,
    "resolveJsonModule": true,
    "types": ["node", "jest"],
    "skipLibCheck": true
  },
  "include": ["**/*.ts", "jest.config.js", ".eslintrc.cjs"],
  "exclude": ["./dist/**/*", "./speedtests/old/**/*"]
}
